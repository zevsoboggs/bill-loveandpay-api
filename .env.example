# Copy to .env and fill in real values. NEVER commit the real .env.
# In production set these in the Railway dashboard, not in a file.

# ─── Database (existing PostgreSQL) ───────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/billing?schema=public"

# ─── Server ───────────────────────────────────────────────────────────────────
# Railway injects PORT automatically; leave unset there.
PORT=4000
NODE_ENV=production
# Public URL of this API (used as the Swagger server URL).
PUBLIC_BASE_URL=https://api.bill.loveandpay.io
# Browser origins allowed to call admin/client APIs (the two SPA domains).
ALLOWED_ORIGINS=https://admin.bill.loveandpay.io,https://lk.bill.loveandpay.io

# ─── Admin auth (JWT) — use a long random secret in production ────────────────
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
JWT_EXPIRES_IN=12h
SEED_ADMIN_EMAIL=admin@loveandpay.io
SEED_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ─── CryptoOffice (deposits / crypto ops) ─────────────────────────────────────
CRYPTO_OFFICE_BASE_URL=https://public.crypto-office.com
CRYPTO_OFFICE_PUBLIC_KEY=REPLACE
CRYPTO_OFFICE_SECRET_KEY=REPLACE
MASTER_WALLET_ADDRESS=REPLACE
MASTER_WALLET_ID=REPLACE

# ─── Payment providers (tranzor) ──────────────────────────────────────────────
SBP_API_BASE=https://sbpu.tranzor.io/api
SBP_API_KEY=REPLACE
PROMPTPAY_API_BASE=https://promptpay.tranzor.io/api/v1
PROMPTPAY_API_KEY=REPLACE

# ─── Yesim eSIM (partner API) ─────────────────────────────────────────────────
YESIM_API_BASE=https://partners-api.yesim.biz
YESIM_API_TOKEN=REPLACE
EUR_USD_FALLBACK=1.08

# ─── Reseller default margins (fraction; 0.04 = 4%) ───────────────────────────
DEFAULT_SBP_MARGIN=0.04
DEFAULT_PROMPTPAY_MARGIN=0.04
DEFAULT_ESIM_MARGIN=0.15

# ─── VPN (vpnd.io reseller) ───────────────────────────────────────────────────
VPND_BASE_URL=https://vpnd.io
VPND_USERNAME=REPLACE
VPND_PASSWORD=REPLACE
# Clean egress proxy — required from datacenters (Railway); vpnd Cloudflare blocks them.
# VPND_PROXY_URL=socks5://user:pass@host:port
VPN_PRICE_USDT=3.0
VPN_DURATION_DAYS=30
DEFAULT_VPN_MARGIN=0.2

# ─── Minimum deposit (USDT) ───────────────────────────────────────────────────
MIN_DEPOSIT_USDT=1000
MIN_DEPOSIT_ESIM_USDT=200

# Love&Pay AML
AML_API_URL=https://loveandpay-aml.fly.dev
AML_API_KEY=lnp_live_xxx
AML_PRICE_USDT=0.5
DEFAULT_AML_MARGIN=0

# PaySpace VCC (corporate crypto cards)
PAYSPACE_BASE_URL=https://app.pay.space
PAYSPACE_API_KEY=xxx
PAYSPACE_SECRET=xxx
PAYSPACE_CALLBACK_BASE_URL=https://lnpapp.rest
